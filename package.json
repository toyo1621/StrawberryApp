{
  "name": "strawberry-game",
  "version": "1.5.1",
  "main": "src/main.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "node scripts/build-production-web.mjs",
    "build:web:e2e": "EXPO_PUBLIC_BASE_URL=/ expo export --platform web --output-dir web-build && node scripts/harden-web-build.mjs",
    "build:native-bundles": "expo export --platform ios --output-dir .tmp/export-ios && expo export --platform android --output-dir .tmp/export-android",
    "check:native-build": "node scripts/check-native-build.mjs",
    "check:web-build": "node scripts/check-web-build.mjs",
    "preview": "node scripts/serve-web.mjs",
    "doctor": "expo-doctor",
    "lint": "eslint --max-warnings 0 src worker/src tests e2e scripts app.config.js playwright.config.ts",
    "typecheck": "npm run typecheck:app && npm run typecheck:worker",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:worker": "tsc -p worker/tsconfig.json --noEmit",
    "test": "npm run test:app && npm run test:worker && npm run test:operational && npm run test:db && npm run test:integration",
    "test:app": "tsc -p tsconfig.test.json && node --test --experimental-test-coverage --test-coverage-include='.tmp/app-tests/src/**/*.js' --test-coverage-lines=94 --test-coverage-branches=84 --test-coverage-functions=88 .tmp/app-tests/tests/*.test.js",
    "test:worker": "tsc -p worker/tsconfig.test.json && node --test --experimental-test-coverage --test-coverage-include='.tmp/worker-tests/*.js' --test-coverage-exclude='.tmp/worker-tests/*.test.js' --test-coverage-lines=91 --test-coverage-branches=81 --test-coverage-functions=92 .tmp/worker-tests/*.test.js",
    "test:db": "node scripts/test-d1-schema.mjs",
    "test:integration": "node scripts/test-worker-integration.mjs",
    "test:operational": "node scripts/test-operational-contracts.mjs",
    "test:e2e": "playwright test",
    "check": "npm run lint && npm run check:maintainability && npm run verify:contracts && npm run verify:privacy && npm run typecheck && npm test && npm run verify:config && npm run audit:high",
    "check:maintainability": "node scripts/check-maintainability.mjs",
    "generate:contracts": "node scripts/generate-ranking-contract.mjs",
    "verify:contracts": "node scripts/generate-ranking-contract.mjs --check && node scripts/verify-ranking-contract.mjs",
    "verify:privacy": "node --no-warnings scripts/verify-privacy.mjs",
    "verify:config": "node --no-warnings scripts/verify-project.mjs",
    "audit:high": "npm audit --audit-level=high",
    "smoke:rankings-api": "node scripts/smoke-rankings-api.mjs",
    "wait:rankings-api": "node scripts/wait-rankings-api.mjs",
    "smoke:web": "node scripts/smoke-web.mjs",
    "smoke:release": "node scripts/smoke-release-consistency.mjs",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "d1:apply-schema": "wrangler d1 execute strawberry-rankings --config worker/wrangler.toml --file worker/schema.sql --remote",
    "d1:migrate": "wrangler d1 migrations apply strawberry-rankings --config worker/wrangler.toml --remote",
    "d1:enable-read-replication": "node scripts/configure-d1-read-replication.mjs",
    "d1:import": "wrangler d1 execute strawberry-rankings --config worker/wrangler.toml --file rankings-import.sql --remote",
    "export:supabase": "node scripts/export-supabase-rankings.mjs",
    "write:d1-import": "node scripts/write-d1-import-sql.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^54.0.36",
    "expo-crypto": "~15.0.9",
    "expo-font": "^14.0.10",
    "expo-haptics": "^15.0.8",
    "expo-image": "^3.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^7.25.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~10.0.0",
    "expo-doctor": "1.20.1",
    "typescript": "~5.9.2",
    "wrangler": "^4.107.0"
  },
  "overrides": {
    "postcss": "8.5.21",
    "sharp": "0.35.3",
    "uuid": "11.1.1"
  },
  "private": true
}
