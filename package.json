{
  "name": "strawberry-game",
  "version": "1.0.0",
  "main": "src/main.tsx",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir web-build",
    "preview": "npx serve web-build",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "d1:apply-schema": "wrangler d1 execute strawberry-rankings --file worker/schema.sql --remote",
    "d1:import": "wrangler d1 execute strawberry-rankings --file rankings-import.sql --remote",
    "export:supabase": "node scripts/export-supabase-rankings.mjs",
    "write:d1-import": "node scripts/write-d1-import-sql.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^54.0.27",
    "expo-font": "^14.0.10",
    "expo-haptics": "^15.0.8",
    "expo-image": "^3.0.11",
    "expo-status-bar": "~3.0.9",
    "flag-icons": "^7.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "typescript": "~5.9.2",
    "wrangler": "^4.107.0"
  },
  "private": true
}
